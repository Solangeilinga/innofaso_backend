# ================================================================
# InnoFaso Backend — Variables d'environnement
# Copie ce fichier en .env et remplis les valeurs
# ================================================================

# ── Serveur ──────────────────────────────────────────────────────
NODE_ENV=development          # development | production
PORT=5000

# ── Base de données PostgreSQL ───────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=innofaso_db2
DB_USER=postgres
DB_PASSWORD=ton_mot_de_passe

# ── Ou : URL complète (Render, Railway, Supabase, etc.) ──────────
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ── JWT ──────────────────────────────────────────────────────────
JWT_SECRET=change_this_very_long_secret_key_minimum_32_chars
JWT_REFRESH_SECRET=change_this_refresh_secret_key_minimum_32_chars
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# ── Frontend (CORS) ──────────────────────────────────────────────
# En dev : URL locale
FRONTEND_URL=http://localhost:3000
# En prod : plusieurs origines séparées par virgule
# FRONTEND_URL=https://innofaso.vercel.app,https://innofaso.com

# ── Uploads ──────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760        # 10 Mo

# ── Email (optionnel) ────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@innofaso.com

# ── IA Service (optionnel) ───────────────────────────────────────
IA_SERVICE_URL=http://localhost:5001

# ── Prod uniquement ──────────────────────────────────────────────
# SERVE_FRONTEND=true         # backend sert aussi le frontend buildé
